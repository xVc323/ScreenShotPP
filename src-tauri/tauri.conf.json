{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScreenShotPP",
  "version": "0.2.0",
  "identifier": "com.pat.screenshotpp",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ScreenShotPP",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/xVc323/ScreenShotPP/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBRjNBODg2NkY4MEIyQTgKUldTb3NvQnZocWp6NnZFMFpadDA4dFpGT1ViK1pQRnlpbVd3bEVIcWhOaGJ5aW1ZTDJFTjM4ck8K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "ScreenShotPP Dev"
    }
  }
}
