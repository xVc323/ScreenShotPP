  "identifier": "default",
  "description": "Capability for the main and overlay windows",
  "windows": ["main", "overlay"],
  "permissions": [
    "core:default",
    "clipboard-manager:allow-write-image",
    "clipboard-manager:allow-write-text",
    "dialog:allow-save"
